# Optional overrides for local deployments.
# Keep real secrets out of source control.
MINDVAULT_CONFIG=config.yaml
MINDVAULT_ADMIN_TOKEN=replace-with-local-admin-token
MINDVAULT_TRUSTED_TOKEN=replace-with-local-trusted-token

# Embedding provider options: none, local, api.
# Default is none. local/api are interface placeholders in this phase and do
# not load real models or call external services.
EMBEDDING_PROVIDER=none
# EMBEDDING_API_KEY=replace-with-api-key-when-api-provider-is-implemented
# EMBEDDING_API_URL=https://api.openai.com/v1

# External validation is disabled by default. Phase 6-A only defines the
# protocol skeleton and does not perform network requests.
EXTERNAL_VALIDATION_ENABLED=false
