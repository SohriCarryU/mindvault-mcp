# Optional overrides for local deployments.
# Keep real secrets out of source control.
MINDVAULT_CONFIG=config.yaml
MINDVAULT_ADMIN_TOKEN=replace-with-local-admin-token
MINDVAULT_TRUSTED_TOKEN=replace-with-local-trusted-token

# Embedding provider options: none, local, api.
# Default is none. local runs a sentence-transformers model on this machine.
# api calls an OpenAI-compatible embeddings endpoint only when explicitly
# configured. Phase 8 can cache and rank usable non-zero vectors in SQLite.
EMBEDDING_PROVIDER=none
# EMBEDDING_LOCAL_MODEL_PATH=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_API_KEY=your_embedding_api_key_here
# EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_MODEL=text-embedding-3-small
# EMBEDDING_API_TIMEOUT=10.0

# External validation is disabled by default. When enabled, Phase 6-C can run
# minimal URL link checks with urllib; tests use fakes and do not call network.
EXTERNAL_VALIDATION_ENABLED=false
EXTERNAL_VALIDATION_TIMEOUT_SECONDS=5.0

# Optional LLM extraction is disabled by default. Phase 7 calls an
# OpenAI-compatible /chat/completions endpoint when enabled, but tests must
# never reach the real network. Keep real keys out of source control.
LLM_EXTRACTION_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=15.0
